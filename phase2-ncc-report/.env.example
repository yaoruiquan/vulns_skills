# NCC 漏洞上报 Skill 配置模板
# 复制此文件为 .env，并只修改路径、账号、密码，以及必要时的端口/profile。

# === 平台配置 ===
# NCC 平台管理中心地址
NCC_PLATFORM_URL=https://www.nccsec.cn/company-center/manage-center

# === Chrome 配置 ===
# Chrome 调试端口（默认 9334）
CHROME_DEBUG_PORT=9334

# Chrome profile 名称（默认 ncc-report）
CHROME_PROFILE_NAME=ncc-report

# 兼容旧变量名；新配置优先使用 CHROME_DEBUG_PORT / CHROME_PROFILE_NAME。
# CLAUDE_CHROME_MCP_PORT=9334
# CLAUDE_CHROME_PROFILE_NAME=ncc-report

# === 数据目录配置 ===
# 漏洞数据根目录（包含 DAS-T* 漏洞文件夹的父目录）
VULN_DATA_DIR=/path/to/your/vulnerability/data

# 运行时 FormContext 输出目录；不要写入正式提交材料目录
FORM_CONTEXT_DIR=/tmp/vulns-skills/phase2-ncc-report/form-contexts

# Python 项目路径（用于导入共享模块，可选）
PYTHON_PROJECT_PATH=/path/to/your/python/project

# === NCC 账号配置（可选） ===
# 如果不使用 Chrome profile 种子模式，可配置账号密码
# 注意：密码明文存储有风险，建议仅用于测试环境
NCC_USERNAME=
NCC_PASSWORD=

# === 钉钉机器人通知（可选）===
# 填写后可用 scripts/dingtalk_notify.py 推送执行结果
DINGTALK_WEBHOOK=
DINGTALK_SECRET=
DINGTALK_KEYWORD=
DINGTALK_ENABLED=true

# === OCR 配置 ===
# 验证码 OCR 服务（ddddocr 本地运行，无需配置）
