# CNVD 漏洞上报 Skill 配置模板
# 复制此文件为 .env，并只修改路径、账号、密码，以及必要时的端口/profile。

# === Chrome 配置 ===
# Chrome 调试端口（默认 9332）
CHROME_DEBUG_PORT=9332

# Chrome profile 名称（默认 cnvd-report）
CHROME_PROFILE_NAME=cnvd-report

# 兼容旧变量名；新配置优先使用 CHROME_DEBUG_PORT / CHROME_PROFILE_NAME。
# CLAUDE_CHROME_MCP_PORT=9332
# CLAUDE_CHROME_PROFILE_NAME=cnvd-report

# === 数据目录配置 ===
# 漏洞数据根目录（包含 DAS-T* 漏洞文件夹的父目录）
VULN_DATA_DIR=/path/to/your/vulnerability/data

# Python 项目路径（用于导入共享模块，可选）
PYTHON_PROJECT_PATH=/path/to/your/python/project

# === CNVD 账号配置（可选） ===
# 如果不使用 Chrome profile 种子模式，可配置账号密码
# 注意：密码明文存储有风险，建议仅用于测试环境
CNVD_EMAIL=
CNVD_PASSWORD=

# === 钉钉机器人通知（可选）===
# 填写后可用 scripts/dingtalk_notify.py 推送执行结果
DINGTALK_WEBHOOK=
DINGTALK_SECRET=
DINGTALK_ENABLED=true
# 监管上报类技能统一使用“监管上报”关键词
DINGTALK_KEYWORD=监管上报

# === 附件上传与下载链接（可选）===
# 提交成功后可将单个漏洞的 CNVD 原始整包 zip 上传到内部服务器，并把下载链接推送到钉钉。
# 默认复用 MSRC 下载服务根目录，但使用独立子目录 cnvd-submissions。
REPORT_UPLOAD_ENABLED=true
REPORT_UPLOAD_HOST=10.50.10.29
REPORT_UPLOAD_PORT=22
REPORT_UPLOAD_USER=root
REPORT_UPLOAD_REMOTE_DIR=/root/msrc-report-downloads/cnvd-submissions
REPORT_DOWNLOAD_BASE_URL=http://10.50.10.29:8080/download/msrc/cnvd-submissions

# SSH 密码不要写入 .env.example；建议使用 SSH key 免密。
# 如必须使用密码，只在本机 .env 中配置 REPORT_UPLOAD_PASSWORD=...

# === OCR 配置 ===
# 验证码 OCR 服务（ddddocr 本地运行，无需配置）
