# CNNVD 上报 Skill 配置模板
# 复制此文件为 .env，并只修改路径、账号、密码，以及必要时的端口/profile。

# ====================
# 登录凭据
# ====================
CNNVD_USERNAME=your_username@example.com
CNNVD_PASSWORD=your_password

# ====================
# 数据路径配置
# ====================
# 漏洞数据根目录（包含 DAS-ID 文件夹）
VULNS_DATA_DIR=/path/to/vulns/date

# 运行时表单上下文 JSON 目录；默认放 /tmp，避免写入 CNNVD 提交材料目录
FORM_CONTEXT_DIR=/tmp/vulns-skills/phase2-cnnvd-report/form-contexts

# 漏洞汇总表 xlsx 文件路径
SUMMARY_TABLE_PATH=/path/to/漏洞汇总表.xlsx

# ====================
# 业务信息配置
# ====================
# 技术支持单位名称
COMPANY_NAME=杭州安恒信息技术股份有限公司

# 默认联系电话（Word 文档无联系方式时使用）
DEFAULT_CONTACT_PHONE=15700082275

# ====================
# Chrome 调试配置
# ====================
# Chrome 远程调试端口
CHROME_DEBUG_PORT=9333

# Chrome profile 名称（用于隔离浏览器数据）
CHROME_PROFILE_NAME=cnnvd-report

# ====================
# 钉钉机器人通知（可选）
# ====================
# 填写后可用 scripts/dingtalk_notify.py 推送执行结果
DINGTALK_WEBHOOK=
DINGTALK_SECRET=
DINGTALK_ENABLED=true
# 监管上报类技能统一使用“监管上报”关键词
DINGTALK_KEYWORD=监管上报

# ====================
# 附件上传与下载链接（可选）
# ====================
# 提交成功后可将单个漏洞的 CNNVD 原始整包 zip 上传到内部服务器，并把下载链接推送到钉钉。
# 默认复用 MSRC 下载服务根目录，但使用独立子目录 cnnvd-submissions。
REPORT_UPLOAD_ENABLED=true
REPORT_UPLOAD_HOST=10.50.10.29
REPORT_UPLOAD_PORT=22
REPORT_UPLOAD_USER=root
REPORT_UPLOAD_REMOTE_DIR=/root/msrc-report-downloads/cnnvd-submissions
REPORT_DOWNLOAD_BASE_URL=http://10.50.10.29:8080/download/msrc/cnnvd-submissions

# SSH 密码不要写入 .env.example；建议使用 SSH key 免密。
# 如必须使用密码，只在本机 .env 中配置 REPORT_UPLOAD_PASSWORD=...

# ====================
# 可选配置
# ====================
# Chrome 用户数据目录（macOS 默认）
# CHROME_USER_DATA_DIR=${HOME}/Library/Application Support/Google/Chrome

# 共享 Chrome 启动脚本目录
# SHARED_SKILLS_DIR=${HOME}/.claude/skills/shared-chrome-devtools
