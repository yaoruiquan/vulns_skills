# CNNVD 上报 Skill 配置模板
# 复制此文件为 .env 并填写实际值

# ====================
# 登录凭据
# ====================
CNNVD_USERNAME=your_username@example.com
CNNVD_PASSWORD=your_password

# ====================
# 数据路径配置
# ====================
# 漏洞数据根目录（包含 DAS-ID 文件夹）
VULNS_DATA_DIR=/path/to/vulns/date

# 漏洞汇总表 xlsx 文件路径
SUMMARY_TABLE_PATH=/path/to/漏洞汇总表.xlsx

# ====================
# 业务信息配置
# ====================
# 技术支持单位名称
COMPANY_NAME=杭州安恒信息技术股份有限公司

# 默认联系电话（Word 文档无联系方式时使用）
DEFAULT_CONTACT_PHONE=15700082275

# ====================
# Chrome 调试配置
# ====================
# Chrome 远程调试端口
CHROME_DEBUG_PORT=9333

# Chrome profile 名称（用于隔离浏览器数据）
CHROME_PROFILE_NAME=cnnvd-report

# ====================
# 可选配置
# ====================
# Chrome 用户数据目录（macOS 默认）
# CHROME_USER_DATA_DIR=${HOME}/Library/Application Support/Google/Chrome

# 共享 skill 目录路径（用于 chrome 启动脚本）
# SHARED_SKILLS_DIR=${HOME}/.claude/skills/shared-chrome-devtools