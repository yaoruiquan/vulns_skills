# 白名单模式：只包含指定的 7 个 skills

# 默认排除所有内容
/*

# 保留 .git 目录
!.git
!.gitignore
!README.md

# 白名单：只包含已发布维护的 skills
!cnvd-weekly-db-update/
!md2wechat/
!msrc-vulnerability-report/
!phase1-material-processor/
!phase2-cnn-report/
!phase2-cnnvd-report/
!phase2-cnvd-report/
!phase2-ncc-report/
!shared-chrome-devtools/
!vulnerability-alert-processor/
!wechat-mp-publisher/

# 排除 skills 内部的子目录中的 .git（如果有）
cnvd-weekly-db-update/**/.git
md2wechat/**/.git
msrc-vulnerability-report/**/.git
phase1-material-processor/**/.git
phase2-cnnvd-report/**/.git
phase2-cnvd-report/**/.git
phase2-ncc-report/**/.git
shared-chrome-devtools/**/.git
vulnerability-alert-processor/**/.git
wechat-mp-publisher/**/.git

# 排除 .DS_Store
.DS_Store
**/.DS_Store
# Environment files with secrets
.env
**/.env

# Local runtime state generated by agents/tools
**/.omc/
**/.claude/
**/captcha*.png
shared-chrome-devtools/profiles/
shared-chrome-devtools/runtime/

# Local archival copies; keep on disk, do not publish
**/references/original-SKILL.md
**/references/original-README.md
