# md2wechat 本地配置示例
# 复制为 .env 后填写真实值；不要提交 .env。

# === 微信公众号接口配置 ===
# 用于创建公众号草稿箱文章。
WECHAT_APPID=
WECHAT_SECRET=

# === md2wechat API 配置（如使用 api mode）===
MD2WECHAT_API_KEY=
MD2WECHAT_BASE_URL=https://www.md2wechat.cn

# === 安全预警默认元数据 ===
WECHAT_DEFAULT_AUTHOR=安恒信息CERT

# 封面模板：支持 .png 或 .pptx。
# PNG 模板会直接叠加标题/CVE/等级文字；PPTX 模板会替换占位符后尝试导出 PNG。
WECHAT_COVER_TEMPLATE=assets/wechat-alert-cover-template.pptx
WECHAT_COVER_OUTPUT_DIR=/tmp/md2wechat-covers
WECHAT_COVER_FONT=

# PPTX 模板占位符建议：
# {{TITLE}} {{CVE}} {{LEVEL}} {{DATE}} {{SUMMARY}}
